# Datadog credentials (required)
DD_API_KEY=${DD_API_KEY}
DD_SITE=${DD_SITE}

# Unified Service Tagging
DD_ENV=corndog-260318
DD_VERSION=1.0.0

# GitHub token for private repo access (optional)
GITHUB_TOKEN=${GITHUB_TOKEN}

# AWS
AWS_REGION=eu-north-1
AWS_PROFILE=default

# SSH
SSH_KEY_NAME=corndog
SSH_PRIVATE_KEY_PATH=~/.ssh/corndog