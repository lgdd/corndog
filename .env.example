# Datadog credentials (required)
DD_API_KEY=${DD_API_KEY}
DD_SITE=${DD_SITE}

# RUM — Browser SDK (create a RUM application in Datadog to obtain these)
DD_APPLICATION_ID=${DD_APPLICATION_ID}
DD_CLIENT_TOKEN=${DD_CLIENT_TOKEN}

# LLM Observability — OpenAI API key for real AI suggestions (optional; falls back to hardcoded)
OPENAI_API_KEY=${OPENAI_API_KEY}

# Unified Service Tagging
DD_ENV=corndog-260318
DD_VERSION=1.0.0

# Source Code Integration (required for Code Origin code previews)
DD_GIT_REPOSITORY_URL=${DD_GIT_REPOSITORY_URL}
DD_GIT_COMMIT_SHA=${DD_GIT_COMMIT_SHA}

# GitHub token for private repo access (optional)
GITHUB_TOKEN=${GITHUB_TOKEN}

# AWS
AWS_REGION=eu-north-1
AWS_PROFILE=default

# SSH
SSH_KEY_NAME=corndog
SSH_PRIVATE_KEY_PATH=~/.ssh/corndog